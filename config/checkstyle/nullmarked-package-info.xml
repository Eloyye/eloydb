<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">
<module name="Checker">
    <module name="RegexpMultiline">
        <property name="format" value="@NullMarked\s+package\s+[\w.]+;"/>
        <property name="minimum" value="1"/>
        <property name="maximum" value="1"/>
        <property name="message" value="package-info.java must mark the package with org.jspecify.annotations.NullMarked."/>
    </module>
</module>
